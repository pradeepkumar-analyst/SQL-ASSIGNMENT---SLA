Que: Create a table Bank which should contains columns like Cust id, Cust name, Bank Balance, active status. Insert some data into that table.
Update the active status to 'Inactive' who ever has Bank Balance below 500.
Delete the customer details who ever has bank balance as 0 and active status as 'Inactive'.


create database tasks;
use tasks;
create table bank(
	  cus_id int auto_increment primary key,
      cus_name varchar(20),
      bank_balance double ,
      active_status varchar (20)
);
desc bank;

insert into bank (cus_name,bank_balance,active_status) values ('Pradeep',200000,'Active'),('Vasanth',10000,'Active'),('vinoth',400,'Active');
select * from bank; 
insert into bank (cus_name,bank_balance,active_status) values ('Aswanth',0,'Active');
select * from bank;
set sql_safe_updates = 0;
update bank set active_status = ('inactive') where bank_balance < 500;
select * from bank;
delete from bank where bank_balance = 0 and active_status= 'Inactive';
select * from bank;
