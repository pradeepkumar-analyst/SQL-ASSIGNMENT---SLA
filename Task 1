####### Task 1 ########
Question: Create a Database named E-Commerce, Create a table as Amazon with product_id,Product_name,price and Qty

Query:
create database E_commerce;
use E_commerce;
create table Amazon (
    product_id int auto_increment primary key, 
    product_name varchar (20) not null,
    prize int not null,
    quantity smallint default 0
);
desc Amazon;
